# Salin ke .env lalu sesuaikan.

# Koneksi PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/siaf?schema=public"

# Port API
PORT=3000

# URL frontend (untuk CORS)
FRONTEND_URL="http://localhost:5173"

# Base URL publik untuk QR (Tahap 4 — dienkode ke dalam QR aset/ruangan sebagai /a/{token} & /r/{token})
PUBLIC_BASE_URL="http://localhost:5173"

# Auth (Tahap 0)
JWT_SECRET="ganti-dengan-string-acak-panjang"
JWT_EXPIRES_IN="7d"

# Akun admin awal (dibuat oleh seed, hanya dipakai sekali — ganti password setelah login pertama)
ADMIN_NAMA="Administrator"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="ganti-password-ini"
