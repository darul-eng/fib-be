# Salin ke .env lalu sesuaikan.

# production | development — mengatur cookie auth `secure` (wajib HTTPS di production)
NODE_ENV=development

# Koneksi PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/siaf?schema=public"

# Port API
PORT=3000

# URL frontend (untuk CORS)
FRONTEND_URL="http://localhost:5173"

# Base URL publik untuk QR (Tahap 4 — dienkode ke dalam QR aset/ruangan sebagai /a/{token} & /r/{token})
PUBLIC_BASE_URL="http://localhost:5173"

# Auth (Tahap 0)
JWT_SECRET="ganti-dengan-string-acak-panjang"
JWT_EXPIRES_IN="7d"

# Akun admin awal (dibuat oleh seed, hanya dipakai sekali — ganti password setelah login pertama)
ADMIN_NAMA="Administrator"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="ganti-password-ini"

# Akun pimpinan awal (dibuat oleh seed, role view-only — ganti password setelah login pertama)
PIMPINAN_NAMA="Dekan"
PIMPINAN_USERNAME="dekan"
PIMPINAN_PASSWORD="ganti-password-ini"

# Akun petugas gudang awal (dibuat oleh seed — ganti password setelah login pertama)
WAREHOUSE_NAMA="Petugas Gudang"
WAREHOUSE_USERNAME="gudang"
WAREHOUSE_PASSWORD="ganti-password-ini"
