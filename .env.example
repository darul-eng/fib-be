# Salin ke .env lalu sesuaikan.

# Koneksi PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/siaf?schema=public"

# Port API
PORT=3000

# URL frontend (untuk CORS)
FRONTEND_URL="http://localhost:5173"

# Base URL publik untuk QR (dipakai saat generate QR di tahap berikutnya)
PUBLIC_BASE_URL="http://localhost:5173"
